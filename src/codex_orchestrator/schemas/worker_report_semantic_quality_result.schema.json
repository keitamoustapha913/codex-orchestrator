    "candidate_scope": {"const": "clean_reconstruction"},
    "patchlet_id": {"type": "string"},
    "attempt_id": {"type": "string"},
    "status": {"enum": ["COMPLETE", "INCOMPLETE", "CONTRADICTORY", "OVERCLAIMED"]},
    "expected_components": {"type": "object"},
    "matched_components": {"type": "array", "items": {"type": "string"}},
    "missing_components": {"type": "array", "items": {"type": "string"}},
    "contradictions": {"type": "array"},
    "overclaims": {"type": "array"},
    "blocking": {"const": false},
    "warnings": {"type": "array"},
    "errors": {"type": "array", "maxItems": 0}
  },
  "additionalProperties": false
}
