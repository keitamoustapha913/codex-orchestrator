{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "clean_candidate_preparation_result",
  "type": "object",
  "required": [
    "schema_version",
    "kind",
    "candidate_scope",
    "patchlet_id",
    "attempt_id",
    "base_commit",
    "base_tree",
    "proposal_patch_sha256",
    "verification_candidate_root",
    "worker_hygiene_status",
    "worker_warning_count",
    "candidate_prepared",
    "durable_integration_updated"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "kind": {"const": "clean_candidate_preparation_result"},
    "candidate_scope": {"const": "clean_reconstruction"},
    "patchlet_id": {"type": "string"},
    "attempt_id": {"type": "string"},
    "base_commit": {"type": "string"},
    "base_tree": {"type": "string"},
    "proposal_patch_sha256": {"type": "string"},
    "verification_candidate_root": {"type": "string"},
    "worker_hygiene_status": {"enum": ["CLEAN", "DEBRIS_PRESENT", "ALLOWED_PATH_VIOLATION", "CONTAINMENT_VIOLATION"]},
    "worker_warning_count": {"type": "integer", "minimum": 0},
    "candidate_prepared": {"type": "boolean"},
    "durable_integration_updated": {"const": false}
  },
  "additionalProperties": false
}
