{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WorkerPatchletReportV2",
  "type": "object",
  "required": [
    "schema_version",
    "kind",
    "patchlet_id",
    "status",
    "changed_product_runtime_file",
    "changed_artifact_files",
    "probe_commands",
    "deterministic_run_counts",
    "root_cause_classification",
    "before_after_state",
    "row_ledger",
    "trace_ledger",
    "cleanup_proof"
  ],
  "properties": {
    "schema_version": {
      "const": "2.0",
      "description": "WorkerPatchletReportV2 version."
    },
    "kind": {
      "const": "worker_patchlet_report",
      "description": "Canonical worker report kind."
    },
    "patchlet_id": {
      "type": "string",
      "description": "Orchestrator-assigned patchlet identity."
    },
    "status": {
      "type": "string",
      "description": "Worker lifecycle status; not proof.",
      "enum": [
        "COMPLETE",
        "VERIFIED_NO_CHANGE_NEEDED",
        "BLOCKED_WITH_EVIDENCE",
        "FAILED_WITH_EVIDENCE"
      ]
    },
    "changed_product_runtime_file": {
      "type": [
        "string",
        "null"
      ],
      "description": "Reported product file; boundary gates remain authoritative."
    },
    "changed_artifact_files": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Reported evidence artifacts."
    },
    "probe_commands": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Worker-described probes; independent proof remains authoritative."
    },
    "deterministic_run_counts": {
      "type": "object",
      "description": "Declared run counts; not independent proof."
    },
    "root_cause_classification": {
      "type": "object",
      "description": "Structured worker diagnosis."
    },
    "before_after_state": {
      "type": "array",
      "description": "Worker state observations."
    },
    "row_ledger": {
      "type": "array",
      "description": "Worker evidence ledger."
    },
    "trace_ledger": {
      "type": "array",
      "description": "Worker trace ledger."
    },
    "cleanup_proof": {
      "type": "string",
      "description": "Worker cleanup observation; hygiene gates remain authoritative."
    },
    "probe_artifact_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "patchlet_id",
          "probe_root",
          "run_id"
        ],
        "properties": {
          "patchlet_id": {
            "type": "string"
          },
          "probe_root": {
            "type": "string"
          },
          "run_id": {
            "type": "string"
          },
          "files": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "path",
                "kind",
                "sha256",
                "size_bytes"
              ],
              "properties": {
                "path": {
                  "type": "string"
                },
                "kind": {
                  "type": "string"
                },
                "sha256": {
                  "type": "string",
                  "pattern": "^[0-9a-f]{64}$"
                },
                "size_bytes": {
                  "type": "integer",
                  "minimum": 0
                },
                "extension": {
                  "type": "string"
                },
                "mime_type": {
                  "type": "string"
                }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      },
      "description": "References to evidence under approved probe roots."
    },
    "semantic_goal_results": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": [
              "criterion_id",
              "kind",
              "expected_value",
              "actual_value",
              "passed"
            ],
            "properties": {
              "criterion_id": {
                "type": "string"
              },
              "kind": {
                "type": "string"
              },
              "expected_value": {},
              "actual_value": {},
              "passed": {
                "type": "boolean"
              },
              "probe_artifact_ref": {
                "type": "object"
              }
            },
            "additionalProperties": true
          },
          {
            "type": "object",
            "required": [
              "goal_item_id",
              "result"
            ],
            "properties": {
              "goal_item_id": {
                "type": "string"
              },
              "result": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": true
          }
        ]
      },
      "description": "Worker semantic observations pending independent proof."
    },
    "blocking_boundary_reason": {
      "type": "string",
      "description": "Worker description of the current blocking boundary."
    },
    "failed_probe_evidence": {
      "type": "string",
      "description": "Worker description of failed probe evidence."
    }
  },
  "additionalProperties": true
}
