{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-orchestrator.local/schemas/target_hygiene_gate_result.schema.json",
  "title": "Target Hygiene Gate Result",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "kind",
    "gate",
    "accepted",
    "patchlet_id",
    "attempt_id",
    "product_runtime_clean",
    "artifact_dirs_present",
    "artifact_dirs_ignored",
    "cache_artifacts_detected",
    "cache_artifacts_removed",
    "unknown_dirty_paths",
    "product_runtime_dirty_paths",
    "git_status_before_hygiene",
    "git_status_after_hygiene",
    "whole_repo_clean_after_hygiene",
    "target_working_tree_clean_after_checkpoint",
    "result_path",
    "reasons"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "kind": {"const": "target_hygiene_gate_result"},
    "gate": {"const": "target_hygiene"},
    "accepted": {"type": "boolean"},
    "patchlet_id": {"type": "string", "pattern": "^P[0-9]+$"},
    "attempt_id": {"type": "string", "minLength": 1},
    "checked_at": {"type": "string"},
    "product_runtime_clean": {"type": "boolean"},
    "artifact_dirs_present": {"type": "array", "items": {"type": "string"}},
    "artifact_dirs_ignored": {"type": "array", "items": {"type": "string"}},
    "cache_artifacts_detected": {"type": "array", "items": {"type": "object"}},
    "cache_artifacts_removed": {"type": "array", "items": {"type": "object"}},
    "unknown_dirty_paths": {"type": "array", "items": {"type": "string"}},
    "product_runtime_dirty_paths": {"type": "array", "items": {"type": "string"}},
    "git_status_before_hygiene": {"type": "array", "items": {"type": "string"}},
    "git_status_after_hygiene": {"type": "array", "items": {"type": "string"}},
    "whole_repo_clean_after_hygiene": {"type": "boolean"},
    "target_working_tree_clean_after_checkpoint": {"type": "boolean"},
    "workflow_dir": {"type": "string"},
    "probe_dir": {"type": "string"},
    "result_path": {"type": "string", "minLength": 1},
    "reasons": {"type": "array", "items": {"type": "string"}}
  }
}
