{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-orchestrator.local/schemas/workflow_identity.schema.json",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "kind",
    "workflow_id",
    "run_id",
    "created_at",
    "repo_root",
    "target_head_sha",
    "target_tree_sha",
    "target_dirty_status_at_start",
    "master_prompt_path",
    "master_prompt_sha256",
    "master_prompt_size_bytes",
    "master_prompt_first_line",
    "worker_mode",
    "use_worktree",
    "until",
    "orchestrator_version",
    "command_args",
    "goal_fingerprint"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "kind": {"const": "workflow_identity"},
    "workflow_id": {"type": "string"},
    "run_id": {"type": "string"},
    "created_at": {"type": "string"},
    "repo_root": {"type": "string"},
    "target_head_sha": {"type": "string"},
    "target_tree_sha": {"type": "string"},
    "target_dirty_status_at_start": {"type": "array", "items": {"type": "string"}},
    "master_prompt_path": {"type": "string"},
    "master_prompt_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "master_prompt_size_bytes": {"type": "integer", "minimum": 0},
    "master_prompt_first_line": {"type": "string"},
    "worker_mode": {"type": "string"},
    "use_worktree": {"type": "boolean"},
    "until": {"type": "string"},
    "orchestrator_version": {"type": "string"},
    "command_args": {"type": "object"},
    "goal_fingerprint": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
  }
}
