{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Work Slices",
  "type": "object",
  "required": ["schema_version", "kind", "slices"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "kind": {"const": "work_slices"},
    "workflow_id": {"type": ["string", "null"]},
    "run_id": {"type": ["string", "null"]},
    "slices": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["work_slice_id", "title", "allowed_product_runtime_file", "slice_type", "goal_item_ids", "proof_obligation_ids", "inventory_node_ids", "depends_on_work_slice_ids", "risk_level", "estimated_complexity", "time_budget_seconds", "prompt_scope"],
        "properties": {
          "work_slice_id": {"type": "string", "pattern": "^WS[0-9]{3}$"},
          "title": {"type": "string", "minLength": 1},
          "allowed_product_runtime_file": {"type": "string", "minLength": 1},
          "slice_type": {"type": "string", "minLength": 1},
          "goal_item_ids": {"type": "array", "items": {"type": "string"}},
          "proof_obligation_ids": {"type": "array", "items": {"type": "string"}},
          "probe_ids": {"type": "array", "items": {"type": "string"}},
          "current_slice_boundary": {
            "type": ["object", "null"],
            "properties": {
              "file": {"type": "string"},
              "symbol": {"type": ["string", "null"]},
              "expected_observation": {},
              "goal_item_id": {"type": ["string", "null"]},
              "goal_item_ids": {"type": "array", "items": {"type": "string"}},
              "proof_obligation_id": {"type": ["string", "null"]},
              "proof_obligation_ids": {"type": "array", "items": {"type": "string"}},
              "probe_ids": {"type": "array", "items": {"type": "string"}}
            },
            "additionalProperties": false
          },
          "future_slice_boundaries": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "file": {"type": "string"},
                "symbol": {"type": ["string", "null"]},
                "expected_observation": {},
                "goal_item_id": {"type": ["string", "null"]},
                "goal_item_ids": {"type": "array", "items": {"type": "string"}},
                "proof_obligation_id": {"type": ["string", "null"]},
                "proof_obligation_ids": {"type": "array", "items": {"type": "string"}},
                "probe_ids": {"type": "array", "items": {"type": "string"}}
              },
              "additionalProperties": false
            }
          },
          "inventory_node_ids": {"type": "array", "items": {"type": "string"}},
          "depends_on_work_slice_ids": {"type": "array", "items": {"type": "string"}},
          "risk_level": {"enum": ["low", "medium", "high"]},
          "estimated_complexity": {"enum": ["small", "medium", "large"]},
          "time_budget_seconds": {"type": "integer", "minimum": 1},
          "prompt_scope": {
            "type": "object",
            "required": ["allowed_edit_file", "memory_compacting_required"],
            "properties": {
              "allowed_context_files": {"type": "array", "items": {"type": "string"}},
              "allowed_edit_file": {"type": "string", "minLength": 1},
              "forbidden_edit_files": {"type": "array", "items": {"type": "string"}},
              "memory_compacting_required": {"const": false}
            },
            "additionalProperties": true
          },
          "slice_change_boundary": {
            "type": "object",
            "required": ["boundary_id", "boundary_type", "allowed_product_runtime_file", "allowed_changes"],
            "properties": {
              "boundary_id": {"type": "string"},
              "boundary_type": {
                "enum": [
                  "text_key_value_update",
                  "section_key_value_update",
                  "line_exact_change",
                  "file_presence_change",
                  "artifact_only",
                  "model_planned_custom_static_boundary",
                  "structured_positive_evidence"
                ]
              },
              "allowed_product_runtime_file": {"type": "string"},
              "goal_item_ids": {"type": "array", "items": {"type": "string"}},
              "proof_obligation_ids": {"type": "array", "items": {"type": "string"}},
              "probe_ids": {"type": "array", "items": {"type": "string"}},
              "current_boundary": {"type": ["object", "null"]},
              "future_boundaries": {"type": "array", "items": {"type": "object"}},
              "allowed_changes": {"type": "array", "items": {"type": "object"}},
              "forbidden_future_goal_item_ids": {"type": "array", "items": {"type": "string"}},
              "forbidden_future_proof_obligation_ids": {"type": "array", "items": {"type": "string"}},
              "forbidden_changes": {"type": "array", "items": {"type": "object"}}
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
