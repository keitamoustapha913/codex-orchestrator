{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Probe Run Validation Result",
  "type": "object",
  "required": ["valid", "patchlet_id", "probe_root", "run_id", "checked_files", "errors"],
  "properties": {
    "valid": {"type": "boolean"},
    "patchlet_id": {"type": "string"},
    "probe_root": {"type": "string"},
    "run_id": {"type": "string"},
    "checked_files": {"type": "array", "items": {"type": "string"}},
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "path", "message"],
        "properties": {
          "code": {"type": "string"},
          "path": {"type": "string"},
          "message": {"type": "string"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
