{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "transaction_group",
  "type": "object",
  "required": ["schema_version", "kind", "transaction_groups"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "kind": {"const": "transaction_groups"},
    "transaction_groups": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "schema_version",
          "kind",
          "transaction_group_id",
          "description",
          "patchlet_ids",
          "invariant_ids",
          "verification_commands",
          "status"
        ],
        "properties": {
          "schema_version": {"const": "1.0"},
          "kind": {"const": "transaction_group"},
          "transaction_group_id": {"type": "string", "pattern": "^TG[0-9]{3}$"},
          "description": {"type": "string"},
          "patchlet_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "invariant_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "verification_commands": {"type": "array", "items": {"type": "string"}},
          "status": {"enum": ["PENDING", "PASSED", "FAILED", "BLOCKED"]},
          "result": {"type": ["object", "null"]},
          "failure_ids": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
