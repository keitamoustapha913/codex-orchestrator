{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "inventory_graph",
  "type": "object",
  "required": ["schema_version", "kind", "nodes", "edges"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "kind": {"const": "inventory_graph"},
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "file", "symbol", "role", "evidence_ids", "confidence"],
        "properties": {
          "id": {"type": "string"},
          "file": {"type": ["string", "null"]},
          "symbol": {"type": ["string", "null"]},
          "role": {"type": "string"},
          "evidence_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "confidence": {"enum": ["high", "medium", "low"]}
        },
        "additionalProperties": true
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "from", "to", "kind", "evidence_ids", "confidence"],
        "properties": {
          "id": {"type": "string"},
          "from": {"type": "string"},
          "to": {"type": "string"},
          "kind": {"type": "string"},
          "evidence_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "confidence": {"enum": ["high", "medium", "low"]}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
