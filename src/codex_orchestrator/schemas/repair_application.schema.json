{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "repair_application",
  "type": "object",
  "required": [
    "schema_version",
    "kind",
    "repair_plan_id",
    "source_failure_ids",
    "applied_action",
    "generated_patchlet_ids",
    "next_stage",
    "product_runtime_files_changed",
    "artifact_files_changed",
    "blind_retry",
    "why"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "kind": {"const": "repair_application"},
    "repair_plan_id": {"type": "string", "pattern": "^RP[0-9]{4}$"},
    "source_failure_ids": {
      "type": "array",
      "items": {"type": "string", "pattern": "^F[0-9]{4}$"}
    },
    "applied_action": {"const": "REQUEST_PATCHLET_REGENERATION"},
    "generated_patchlet_ids": {
      "type": "array",
      "items": {"type": "string"}
    },
    "next_stage": {"const": "PATCHLET_REGENERATION_REQUIRED"},
    "product_runtime_files_changed": {
      "type": "array",
      "items": {"type": "string"}
    },
    "artifact_files_changed": {
      "type": "array",
      "items": {"type": "string"}
    },
    "blind_retry": {"const": false},
    "why": {"type": "string", "minLength": 1},
    "created_at": {"type": "string"}
  },
  "additionalProperties": true
}
