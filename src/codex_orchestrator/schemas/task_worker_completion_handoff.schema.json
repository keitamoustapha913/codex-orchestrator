{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Task Worker Completion Handoff",
  "type": "object",
  "required": [
    "schema_version",
    "kind",
    "patchlet_id",
    "status",
    "probe_commands",
    "deterministic_run_counts",
    "root_cause_classification",
    "before_after_state",
    "row_ledger",
    "trace_ledger",
    "cleanup_proof"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "kind": {"const": "task_worker_completion_handoff"},
    "patchlet_id": {"type": "string"},
    "status": {
      "enum": [
        "COMPLETE",
        "VERIFIED_NO_CHANGE_NEEDED",
        "BLOCKED_WITH_EVIDENCE",
        "FAILED_WITH_EVIDENCE"
      ]
    },
    "probe_commands": {"type": "array"},
    "deterministic_run_counts": {"type": "object"},
    "root_cause_classification": {
      "type": "object",
      "description": "Diagnostic observations for the report producer; these remain untrusted worker claims."
    },
    "before_after_state": {"type": "array"},
    "row_ledger": {"type": "array"},
    "trace_ledger": {"type": "array"},
    "cleanup_proof": {"type": "string"},
    "semantic_goal_results": {"type": "array"},
    "blocking_boundary_reason": {"type": "string"},
    "failed_probe_evidence": {"type": "string"}
  },
  "additionalProperties": true
}
