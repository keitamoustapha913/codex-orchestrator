{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Patchlet Index",
  "type": "object",
  "required": ["schema_version", "kind", "patchlets"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "kind": {"const": "patchlet_index"},
    "patchlets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "schema_version", "kind", "patchlet_id", "subprompt_path", "master_goal_ids", "invariant_ids",
          "evidence_ids", "graph_node_ids", "allowed_product_runtime_file", "allowed_artifact_dirs",
          "transaction_group_id", "depends_on", "status"
        ],
        "properties": {
          "schema_version": {"const": "1.0"},
          "kind": {"const": "patchlet"},
          "patchlet_id": {"type": "string"},
          "subprompt_path": {"type": "string"},
          "master_goal_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "invariant_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "evidence_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "graph_node_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "allowed_product_runtime_file": {"type": "string"},
          "allowed_artifact_dirs": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "slice_change_boundary": {"type": ["object", "null"]},
          "boundary_enforcement_status": {"type": ["string", "null"]},
          "transaction_group_id": {"type": "string"},
          "depends_on": {"type": "array", "items": {"type": "string"}},
          "status": {"enum": ["PENDING", "IN_PROGRESS", "COMPLETE", "VERIFIED_NO_CHANGE_NEEDED", "BLOCKED_WITH_EVIDENCE", "BLOCKED_BY_FAILED_DEPENDENCY", "FAILED_WITH_EVIDENCE"]}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
