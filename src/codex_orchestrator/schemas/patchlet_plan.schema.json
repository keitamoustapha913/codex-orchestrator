{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Patchlet Plan",
  "type": "object",
  "required": ["schema_version", "kind", "patchlets"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "kind": {"const": "patchlet_plan"},
    "workflow_id": {"type": ["string", "null"]},
    "run_id": {"type": ["string", "null"]},
    "patchlets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["patchlet_id", "work_slice_id", "allowed_product_runtime_file", "allowed_product_runtime_files", "proof_obligation_ids", "goal_item_ids", "dependency_patchlet_ids", "downstream_patchlet_ids", "time_budget_seconds", "prompt_budget_policy", "expected_patchlet_statuses"],
        "properties": {
          "patchlet_id": {"type": "string", "pattern": "^P[0-9]{4}$"},
          "work_slice_id": {"type": "string", "pattern": "^WS[0-9]{3}$"},
          "allowed_product_runtime_file": {"type": "string", "minLength": 1},
          "allowed_product_runtime_files": {"type": "array", "minItems": 1, "maxItems": 1, "items": {"type": "string", "minLength": 1}},
          "proof_obligation_ids": {"type": "array", "items": {"type": "string"}},
          "goal_item_ids": {"type": "array", "items": {"type": "string"}},
          "dependency_patchlet_ids": {"type": "array", "items": {"type": "string"}},
          "downstream_patchlet_ids": {"type": "array", "items": {"type": "string"}},
          "time_budget_seconds": {"type": "integer", "minimum": 1},
          "prompt_budget_policy": {
            "type": "object",
            "required": ["must_fit_within_timeout", "avoid_memory_compacting", "max_scope_files", "max_product_runtime_edit_files"],
            "properties": {
              "must_fit_within_timeout": {"const": true},
              "avoid_memory_compacting": {"const": true},
              "max_scope_files": {"type": "integer", "maximum": 1},
              "max_product_runtime_edit_files": {"const": 1}
            },
            "additionalProperties": true
          },
          "expected_patchlet_statuses": {"type": "array", "minItems": 4, "items": {"type": "string"}}
          ,
          "slice_change_boundary": {"type": ["object", "null"]},
          "boundary_enforcement_status": {"type": ["string", "null"]}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
